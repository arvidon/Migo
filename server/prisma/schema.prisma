// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Blog{
  id String @id @default(uuid())
  slug String @unique
  title String
  banner String?
  des String? 
  content Json?
  tags String[]

  authorId String 
  author User @relation(fields: [authorId], references:[id])


  total_likes Int @default(0)
  total_comments Int @default(0)
  total_reads Int @default(0)
  total_parent_comments Int @default(0)

  comments Comment[]

  draft Boolean @default(false)
  publishedAt DateTime @default(now())

  notifications Notification[]

  @@map("blogs")

}

model Comment{
  id String @id @default(uuid())

  blogId String
  blog Blog @relation(fields:[blogId], references:[id])

  blogAuthorId String
  blogAuthor User @relation("BlogAuthorComments", fields:[blogAuthorId], references:[id])

  comment String

  commentById String
  commentedBy User @relation("UserComments", fields:[commentById], references:[id])

  isReply Boolean @default(false)

  parentId String?
  parent Comment? @relation("CommentReplies", fields:[parentId], references:[id])

  children Comment[] @relation("CommentReplies")

  notificationComment Notification[] @relation("NotificationComment")
  reply Notification[] @relation("NotificationReply")
  repliedOnComment Notification[] @relation("NotificationRepliedOn")

  commentedAt DateTime @default(now())

  @@map("comments")
}

enum NotificationType{
  like
  comment
  reply
}

model Notification{
  id String @id @default(uuid())

  type NotificationType

  blogId String
  blog Blog @relation(fields:[blogId], references:[id])

  notificationForId String
  notificationFor User @relation("NotificationRecipient", fields:[notificationForId], references:[id])

  userId String
  user User @relation("NotificationSender", fields:[userId], references:[id])

  commentId String?
  comment Comment? @relation("NotificationComment", fields:[commentId], references:[id])

  replyId String?
  reply Comment? @relation("NotificationReply", fields:[replyId], references:[id])

  repliedOnCommentId String?
  repliedOnComment Comment? @relation("NotificationRepliedOn", fields:[repliedOnCommentId], references:[id])

  seen Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification")

}

model User{
  id String @id @default(uuid())
  blogs Blog[]

  fullName String
  email String @unique
  password String?
  username String? @unique
  bio String @default("")
  profile_img String

  youtube String @default("")
  twitter String @default("")
  instagram String @default("")
  facebook String @default("")
  github String @default("")
  website String @default("")

  total_posts Int @default(0)
  total_reads Int @default(0)

  google_auth Boolean @default(false)

  comments Comment[] @relation("UserComments")
  blogAuthorComments Comment[] @relation("BlogAuthorComments")

  
  notificationSent Notification[] @relation("NotificationSender")
  notificationsReceived Notification[] @relation("NotificationRecipient")

  joinedAt DateTime @default(now())

  @@map("users")
}




